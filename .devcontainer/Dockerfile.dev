FROM python:3.11-slim

# 作業ディレクトリの設定
WORKDIR /app

# システムパッケージのインストール
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# Pythonパッケージのインストール
COPY requirements.txt /app/
RUN pip install --no-cache-dir -r /app/requirements.txt

# アプリケーションコードはvolumeでマウントするため、COPYは不要

# デフォルトコマンド（devcontainerではここを使わない）
CMD ["/bin/bash"]
